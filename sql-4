 -- whole data of two tables

-- inner join

select e.empid, e.empname,e.salary,d.deptname,d.location
from emp e inner join department d
on e.deptid = d.deptid
order by empid;


-- Left Join   ---> return all emp details including those without a dept  and not matching depat

select e.empid, e.empname, e.salary,d.deptid,d.deptname,d.location
from emp e left join department d
on e.deptid=d.deptid;


-- Right Join 


select e.empid, e.empname, e.salary,d.deptid,d.deptname,d.location
from emp e right join department d
on e.deptid=d.deptid;


