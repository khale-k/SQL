-- keys

-- primary key    -- unique , not null. only one primary key in table 

-- foreign key  -- one table primary key linked to another table then it is foreign key


create table emp(
empid int primary key,
empname varchar(50) not null,
salary int,
deptid int,
foreign key(deptid) references department(deptid)
);

