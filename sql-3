-- groupby

select location,sum(budget) as totalbudget 
from department
group by location;


select location,min(budget) from department 
group by location ;



-- Having  ------ only when we are using condition for aggregate functions


select location,count(*) as deptcount
from department
group by location
having count(*) >2;



